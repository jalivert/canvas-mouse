(function root(): void {
  const root = document.querySelector<HTMLDivElement>('#root')!

  const app: Component = App();

  root.appendChild(app.element);
})();


(function tick(): void {
  let previousFrame = performance.now();
  let buffer = Array();

  const channel = COMM.createChannel();

  const tps = 60;
  let lastTime = performance.now();
  function tick() {
    const now = performance.now();
    if ((now - lastTime) > (1000 / tps)) {
      lastTime = now;
      COMM.sendToChannel(channel, { type: "TICK" });
      //  what's the real fps?
      buffer.push(Math.floor(1000 / (performance.now() - previousFrame)));
      if (buffer.length > 50) {
        buffer.shift();
      }
      previousFrame = performance.now();
    }



    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);

  function fps() {
    const sum = buffer.reduce((acc, n) => acc + n);
    const mean = Math.round(sum / buffer.length);
    buffer = Array();

    COMM.send({ type: 'FPS', value: mean });
    setTimeout(fps, 1000);
  }

  setTimeout(fps, 1000);


})();


(function mouse(): void {
  window.addEventListener('mousemove', (ev: MouseEvent) => {
    const x = ev.clientX;
    const y = ev.clientY;

    mouseX = x;
    mouseY = y;
  })
})();


