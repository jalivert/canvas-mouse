function Cell(ctx: CanvasRenderingContext2D, row: number, column: number): void {
  let saturation = 80;
  let lightness = 50;

  //  compute the position of the top-left corner and bottom-right corner
  const top = row * CELL_SIZE;
  const left = column * CELL_SIZE;
  const bottom = top + CELL_SIZE;
  const right = left + CELL_SIZE;

  const midX = left + CELL_SIZE / 2;
  const midY = top + CELL_SIZE / 2;

  function render() {
    const distA = Math.sqrt(Math.pow(mouseX - midX, 2) + Math.pow(mouseY - midY, 2));
    const longest = Math.sqrt(Math.pow(window.innerWidth, 2) + Math.pow(window.innerHeight, 2));
    const distR = Math.round((distA / longest) * 100);

    const hueRel = Math.round((distR * 3.6) % 360);

    ctx.fillStyle = `hsl(${hueRel}, ${saturation}%, ${lightness}%)`;
    ctx.fillRect(left, top, CELL_SIZE, CELL_SIZE);
    // ctx.strokeRect(top, left, CELL_SIZE, CELL_SIZE);
    // ctx.font = "5px serif";
    // ctx.fillStyle = 'black';
    // ctx.fillText(`${midX}:${midY}`, top, left)
  }



  COMM.listen((msg: Msg) => {
    if (msg.type === "TICK") {

      render();

    }
  });

}




