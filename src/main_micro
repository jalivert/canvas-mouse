const CELL_SIZE = 5;

let mouseX: number = 0;
let mouseY: number = 0;



interface Component {
  element: HTMLElement,
  ID: string
}

interface Msg {
  type: string;
  [key: string]: any;
}


const COMM = (() => {
  const comm = {
    counter: 0,
    get nextID() {
      return (this.counter++).toString();
    },
    q: Array(),
    send: function (msg: Msg) {
      this.q.push(msg);
    },
    receivers: Array(),
    listen: function (callback: (msg: Msg) => void) {
      this.receivers.push(callback);
    },
    channels: Array(),
    createChannel: function (): number {
      const ind = this.channels.length;
      this.channels.push([]);
      return ind;
    },
    sendToChannel: function (channelID: number, msg: Msg): void {
      this.channels[channelID].push(msg);
    },
  }

  setTimeout(work, 0);

  function work() {
    if (comm.q.length > 0) {
      const job = comm.q.shift();
      comm.receivers.forEach(callback => queueMicrotask(() => callback(job)));
      // comm.receivers.forEach(callback => setTimeout(() => callback(job), 0));
    }

    comm.channels.forEach((stack: Array<Msg>, i) => {
      if (stack.length > 0) {
        const job = stack.pop();
        comm.channels[i] = Array();
        comm.receivers.forEach(callback => queueMicrotask(() => callback(job)));
        // comm.receivers.forEach(callback => setTimeout(() => callback(job), 0));
      }
    })

    setTimeout(work, 0);
  }

  return comm;
})();


